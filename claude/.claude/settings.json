{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/scripts/statusline.sh\""
  },
  "env": {
    "ANTHROPIC_MODEL": "opusplan",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_ZOXIDE": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(npm init:*)",
      "Bash(npm install:*)",
      "Bash(yarn install:*)",
      "Bash(pnpm install:*)",
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(echo:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(brew install:*)",
      "Bash(chmod 777:*)",
      "Bash(gh repo delete:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git config:*)",
      "Bash(git rebase:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(sudo:*)",
      "Read(.env*)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(.env.*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(psql:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin --force:*)",
      "Bash(git push origin -f:*)"
    ],
    "ask": ["Bash(curl:*)", "Bash(git reset:*)", "Bash(git push:*)", "Bash(rm:*)"],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Submarine.aiff"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "agent-browser": {
      "source": {
        "source": "github",
        "repo": "vercel-labs/agent-browser"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "chrome-devtools-mcp": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "playwright-cli": {
      "source": {
        "source": "github",
        "repo": "microsoft/playwright-cli"
      }
    },
    "storybook": {
      "source": {
        "source": "github",
        "repo": "storybookjs/mcp"
      }
    },
    "tsumiki": {
      "source": {
        "source": "github",
        "repo": "classmethod/tsumiki"
      }
    },
    "vercel-plugin": {
      "source": {
        "source": "github",
        "repo": "vercel/vercel-plugin"
      }
    },
    "webwright": {
      "source": {
        "source": "github",
        "repo": "microsoft/Webwright"
      }
    }
  },
  "language": "英語で考えて、日本語で回答する。",
  "effortLevel": "xhigh",
  "askUserQuestionTimeout": "10m",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "editorMode": "normal",
  "preferredNotifChannel": "ghostty",
  "autoCompactEnabled": true,
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
