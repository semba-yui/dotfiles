{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": true,
  "askUserQuestionTimeout": "10m",
  "autoCompactEnabled": true,
  "editorMode": "normal",
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "agent-browser@agent-browser": false,
    "atlassian@claude-plugins-official": false,
    "atomic-agents@claude-plugins-official": false,
    "canva@knowledge-work-plugins": false,
    "chrome-devtools-mcp@chrome-devtools-plugins": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "codex@openai-codex": false,
    "context7@claude-plugins-official": false,
    "document-skills@anthropic-agent-skills": false,
    "feature-dev@claude-plugins-official": false,
    "figma@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "mattpocock-skills@mattpocock": false,
    "microsoft-docs@claude-plugins-official": false,
    "miro@claude-plugins-official": false,
    "miro@knowledge-work-plugins": false,
    "playwright@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "redis-development@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false,
    "semgrep@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "storybook@storybook": false,
    "superpowers@claude-plugins-official": false,
    "terraform@claude-plugins-official": false,
    "tsumiki@tsumiki": false,
    "typescript-lsp@claude-plugins-official": false,
    "vercel@claude-plugins-official": false
  },
  "env": {
    "ANTHROPIC_MODEL": "opusplan",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_ZOXIDE": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "extraKnownMarketplaces": {
    "agent-browser": {
      "source": {
        "repo": "vercel-labs/agent-browser",
        "source": "github"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "repo": "ast-grep/agent-skill",
        "source": "github"
      }
    },
    "chrome-devtools-mcp": {
      "source": {
        "repo": "ChromeDevTools/chrome-devtools-mcp",
        "source": "github"
      }
    },
    "knowledge-work-plugins": {
      "source": {
        "repo": "anthropics/knowledge-work-plugins",
        "source": "github"
      }
    },
    "mattpocock": {
      "source": {
        "repo": "mattpocock/skills",
        "source": "github"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    },
    "storybook": {
      "source": {
        "repo": "storybookjs/mcp",
        "source": "github"
      }
    },
    "tsumiki": {
      "source": {
        "repo": "classmethod/tsumiki",
        "source": "github"
      }
    },
    "vercel-plugin": {
      "source": {
        "repo": "vercel/vercel-plugin",
        "source": "github"
      }
    },
    "webwright": {
      "source": {
        "repo": "microsoft/Webwright",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "afplay /System/Library/Sounds/Submarine.aiff",
            "type": "command"
          }
        ],
        "matcher": "idle_prompt"
      },
      {
        "hooks": [
          {
            "command": "afplay /System/Library/Sounds/Ping.aiff",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/semba/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "afplay /System/Library/Sounds/Funk.aiff",
            "type": "command"
          }
        ]
      }
    ]
  },
  "inputNeededNotifEnabled": true,
  "language": "英語で考えて、日本語で回答する。",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(npm init:*)",
      "Bash(npm install:*)",
      "Bash(yarn install:*)",
      "Bash(pnpm install:*)",
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(echo:*)",
      "WebSearch"
    ],
    "ask": ["Bash(curl:*)", "Bash(git reset:*)", "Bash(git push:*)", "Bash(rm:*)"],
    "defaultMode": "auto",
    "deny": [
      "Bash(brew install:*)",
      "Bash(chmod 777:*)",
      "Bash(gh repo delete:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git config:*)",
      "Bash(git rebase:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(sudo:*)",
      "Read(.env*)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(.env.*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(psql:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin --force:*)",
      "Bash(git push origin -f:*)"
    ]
  },
  "preferredNotifChannel": "ghostty",
  "remoteControlAtStartup": true,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "bash \"$HOME/.claude/scripts/statusline.sh\"",
    "type": "command"
  },
  "theme": "dark",
  "tui": "fullscreen"
}
